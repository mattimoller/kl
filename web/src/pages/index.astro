---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'klrunning';
const tagline = 'A running club. Site under construction.';
---

<BaseLayout title={title} description={tagline}>
  <main class="hero">
    <h1>{title}</h1>
    <p>{tagline}</p>
  </main>
</BaseLayout>

<style>
  .hero {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    text-align: center;
    padding: var(--space-5);
  }
  h1 {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.04em;
  }
  p {
    color: var(--color-muted);
    margin-top: var(--space-2);
    font-size: 1.125rem;
  }
</style>
