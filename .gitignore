# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- Node / Astro ---
node_modules/
dist/
.astro/
*.tsbuildinfo

# --- Env ---
.env
.env.*
!.env.example

# --- Terraform ---
# State and crash logs are local-only; remote state is the source of truth.
*.tfstate
*.tfstate.*
.terraform/
crash.log
crash.*.log
*.tfplan

# Local overrides used by individual operators
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# tfvars may contain billing IDs, project numbers, secrets.
# Commit *.tfvars.example with placeholder values instead.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Note: .terraform.lock.hcl is intentionally NOT ignored — committing it
# pins provider versions for reproducible plans across machines and CI.
